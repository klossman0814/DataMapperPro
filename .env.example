REDIS_URL=redis://localhost:6382
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
PORT=3002
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
MAX_FILE_SIZE=500mb
CORS_ORIGIN=http://localhost:5175
